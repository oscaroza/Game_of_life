def update_speed():
    global speed
    ratio = (handle_x - SLIDER.x) / SLIDER.width
    raw_speed = MIN_SPEED + ratio * (MAX_SPEED - MIN_SPEED)
    speed = max(MIN_SPEED, min(MAX_SPEED, int(round(raw_speed))))


def move_handle_to(mouse_x):
    global handle_x
    handle_x = max(SLIDER.x, min(mouse_x, SLIDER.right))
    update_speed()


def clear_grid():
    global generation_count
    gol.clear_grid(gol.grid, ROWS, COLS)
    generation_count = 0


def parse_pattern_map(pattern_map):
    coords = []
    for row, line in enumerate(pattern_map):
        for col, char in enumerate(line):
            if char == "*":
                coords.append((row, col))
    return coords


PULSAR = parse_pattern_map(PULSAR_MAP)

gol.reset_module_grid()
paused = True
user_mode = False
generation_timer = 0.0
generation_count = 0
BACKGROUND_SURFACE = make_background_surface()


def place_pattern_center(pattern_coords):
    global user_mode, generation_count
    gol.place_pattern_center(gol.grid, pattern_coords, ROWS, COLS)
    user_mode = False
    generation_count = 0


def random_initialisation():
    global user_mode, generation_count
    gol.clear_grid(gol.grid, ROWS, COLS)
    gol.randomize_grid(gol.grid, ROWS, COLS)
    user_mode = False
    generation_count = 0


def point_in_grid(pos):
    x, y = pos
    return GRID_X <= x < GRID_X + GRID_SIZE and GRID_Y <= y < GRID_Y + GRID_SIZE


def toggle_cell_from_mouse(pos):
    x, y = pos
    col = (x - GRID_X) // CELL_SIZE
    row = (y - GRID_Y) // CELL_SIZE
    gol.toggle_cell(gol.grid, row, col, ROWS, COLS)


async def main():
    global dragging, paused, user_mode, generation_timer, generation_count

    running = True
    while running:
        dt = clock.tick(60)
        mouse_pos = pygame.mouse.get_pos()

        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
                break

            if event.type == pygame.MOUSEBUTTONDOWN:
                click_pos = event.pos

                if start_button.collidepoint(click_pos):
                    paused = False
                    user_mode = False
                elif pause_button.collidepoint(click_pos):
                    paused = True
                elif reset_button.collidepoint(click_pos):
                    clear_grid()
                    paused = True
                    user_mode = False
                elif SLIDER.collidepoint(click_pos) or math.dist(
                    click_pos, (handle_x, SLIDER.y + SLIDER.height // 2)
                ) <= HANDLE_RADIUS + 4:
                    dragging = True
                    move_handle_to(click_pos[0])
                elif point_in_grid(click_pos) and (paused or user_mode):
                    toggle_cell_from_mouse(click_pos)

            elif event.type == pygame.MOUSEBUTTONUP:
                dragging = False

            elif event.type == pygame.MOUSEMOTION and dragging:
                move_handle_to(event.pos[0])

            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_SPACE:
                    paused = not paused
                    if not paused:
                        user_mode = False
                elif event.key == pygame.K_g:
                    place_pattern_center(GLIDER)
                    paused = True
                elif event.key == pygame.K_b:
                    place_pattern_center(BLINKER)
                    paused = True
                elif event.key == pygame.K_p:
                    place_pattern_center(PULSAR)
                    paused = True
                elif event.key == pygame.K_r:
                    place_pattern_center(R_PENTOMINO)
                    paused = True
                elif event.key == pygame.K_u:
                    clear_grid()
                    paused = True
                    user_mode = True
                elif event.key == pygame.K_i:
                    random_initialisation()
                    paused = True

        if paused:
            generation_timer = 0.0
        else:
            generation_timer += dt
            step_interval = 1000.0 / max(speed, 1)
            while generation_timer >= step_interval:
                gol.grid = gol.next_generation(gol.grid, ROWS, COLS)
                generation_timer -= step_interval
                generation_count += 1

        render_ui(mouse_pos)

        # Yield control to browser event loop in WebAssembly builds.
        await asyncio.sleep(0)

    pygame.quit()


if __name__ == "__main__":
    asyncio.run(main())
