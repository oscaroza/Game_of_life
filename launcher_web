def draw_buttons(mouse_pos):
    button_specs = [
        ("RUN", start_button, BTN_PLAY, (not paused and not user_mode)),
        ("PAUSE", pause_button, BTN_PAUSE, (paused and not user_mode)),
        ("RESET", reset_button, BTN_RESET, False),
    ]

    for label, rect, base_color, selected in button_specs:
        hovered = rect.collidepoint(mouse_pos)
        fill_color = base_color

        if hovered:
            fill_color = blend(fill_color, (255, 255, 255), 0.16)
        if selected:
            fill_color = blend(fill_color, (255, 255, 255), 0.12)

        border_color = blend(fill_color, (255, 255, 255), 0.34)

        draw_shadow(rect, radius=14, offset=(0, 4), alpha=60)
        pygame.draw.rect(screen, fill_color, rect, border_radius=14)
        pygame.draw.rect(screen, border_color, rect, 2, border_radius=14)

        text_surface = font_button.render(label, True, (255, 255, 255))
        screen.blit(text_surface, text_surface.get_rect(center=rect.center))


