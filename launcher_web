def blend(color_a, color_b, ratio):
    ratio = max(0.0, min(1.0, ratio))
    return tuple(
        int(color_a[index] + (color_b[index] - color_a[index]) * ratio)
        for index in range(3)
    )


def make_background_surface():
    background = pygame.Surface((WIDTH, HEIGHT))

    for y in range(HEIGHT):
        factor = y / (HEIGHT - 1)
        color = blend(BG_TOP, BG_BOTTOM, factor)
        pygame.draw.line(background, color, (0, y), (WIDTH, y))

    glow = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
    pygame.draw.circle(glow, (*GLOW_CYAN, 38), (220, 150), 230)
    pygame.draw.circle(glow, (*GLOW_ORANGE, 28), (980, 640), 210)
    pygame.draw.circle(glow, (65, 110, 210, 22), (1040, 150), 180)

    for x in range(0, WIDTH, 16):
        pygame.draw.line(glow, (255, 255, 255, 8), (x, 0), (x - 120, HEIGHT), 1)

    background.blit(glow, (0, 0))
    return background


def draw_shadow(rect, radius=18, offset=(0, 6), alpha=70):
    shadow_surface = pygame.Surface((rect.width + 24, rect.height + 24), pygame.SRCALPHA)
    pygame.draw.rect(
        shadow_surface,
        (0, 0, 0, alpha),
        shadow_surface.get_rect(),
        border_radius=radius + 8,
    )
    screen.blit(shadow_surface, (rect.x - 12 + offset[0], rect.y - 10 + offset[1]))


def draw_panel(rect, fill_color, border_color, radius=18, with_shadow=True):
    if with_shadow:
        draw_shadow(rect, radius=radius)

    pygame.draw.rect(screen, fill_color, rect, border_radius=radius)
    pygame.draw.rect(screen, border_color, rect, 2, border_radius=radius)


